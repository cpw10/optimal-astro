---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const caseStudies = await getCollection('case-studies');
---

<BaseLayout title="Case Studies | Optimal" description="Client success stories">
  <section class="py-16">
    <div class="container-custom">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Case Studies</h1>
      <p class="text-xl text-gray-600 mb-12">
        See how we've helped leading brands improve their web performance
      </p>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {caseStudies.map((study) => (
          <article class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow">
            <div class="p-6">
              <span class="text-sm text-blue-600 font-medium">
                {study.data.industry}
              </span>
              <h2 class="text-xl font-semibold text-gray-900 mt-2 mb-3">
                <a href={`/case-studies/${study.id}/`} class="hover:text-blue-600 transition-colors">
                  {study.data.client}
                </a>
              </h2>
              {study.data.description && (
                <p class="text-gray-600 text-sm">
                  {study.data.description}
                </p>
              )}
              <a
                href={`/case-studies/${study.id}/`}
                class="inline-flex items-center mt-4 text-blue-600 text-sm font-medium hover:underline"
              >
                Read case study
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
