---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const page = await getEntry('pages', 'contact');
const { intro_text, address, form_services } = page.data;
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <section class="py-16">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-4xl font-bold text-gray-900 mb-4">Contact Us</h1>
        {intro_text && (
          <p
            class="text-xl text-gray-600 mb-12"
            data-editable="text"
            data-prop="intro_text"
          >
            {intro_text}
          </p>
        )}

        <div class="grid md:grid-cols-2 gap-12">
          <form class="space-y-6">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Your Name</label>
              <input
                type="text"
                name="name"
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                required
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Your Email</label>
              <input
                type="email"
                name="email"
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                required
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Company</label>
              <input
                type="text"
                name="company"
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Service</label>
              <select
                name="service"
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              >
                <option value="">Select a service</option>
                {form_services?.map((service) => (
                  <option value={service}>{service}</option>
                ))}
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Message</label>
              <textarea
                name="message"
                rows="4"
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                required
              ></textarea>
            </div>
            <button type="submit" class="btn btn-primary w-full">
              Send Message
            </button>
          </form>

          <div>
            {address && (
              <div class="mb-8">
                <h3 class="font-semibold text-gray-900 mb-2">Our Office</h3>
                <address class="text-gray-600 not-italic">
                  {address.name && <p>{address.name}</p>}
                  {address.street && <p>{address.street}</p>}
                  {address.city && address.state && <p>{address.city}, {address.state}</p>}
                </address>
              </div>
            )}

            <div>
              <h3 class="font-semibold text-gray-900 mb-2">Connect With Us</h3>
              <div class="flex gap-4">
                <a
                  href="https://www.linkedin.com/company/thisisoptimal.com"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-gray-600 hover:text-blue-600 transition-colors"
                >
                  LinkedIn
                </a>
                <a
                  href="https://twitter.com/thisisoptimal"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-gray-600 hover:text-blue-600 transition-colors"
                >
                  Twitter
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
