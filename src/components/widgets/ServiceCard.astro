---
interface Props {
  title: string;
  description?: string;
  icon?: string;
  link?: string;
}

const { title, description, icon, link } = Astro.props;
---

<div class="bg-white rounded-lg shadow-sm border border-gray-100 p-6 hover:shadow-md transition-shadow">
  {icon && (
    <div class="w-12 h-12 mb-4">
      <img src={icon} alt="" class="w-full h-full object-contain" />
    </div>
  )}

  <h3 class="text-xl font-semibold text-gray-900 mb-2">
    {link ? (
      <a href={link} class="hover:text-blue-600 transition-colors">
        {title}
      </a>
    ) : (
      title
    )}
  </h3>

  {description && (
    <p class="text-gray-600 text-sm">
      {description}
    </p>
  )}

  {link && (
    <a href={link} class="inline-flex items-center mt-4 text-blue-600 text-sm font-medium hover:underline">
      Learn more
      <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  )}
</div>
